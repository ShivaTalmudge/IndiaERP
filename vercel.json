{
  "version": 2,
  "builds": [
    {
      "src": "erp_saas/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "erp_saas/wsgi.py"
    }
  ]
}
